# Скопируйте в `.env` и заполните локально. Файл `.env` не коммитится.

# Travelpayouts / Aviasales Data API (токен из кабинета партнёра)
TRAVELPAYOUTS_TOKEN=

# Telegram Bot API
BOT_TOKEN=

# LLM provider API key (для этапа рекомендаций)
LLM_API_KEY=
USE_LLM_BRIEF_PARSER=false
LLM_PARSER_MODEL=gpt-4o-mini
